<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>


<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Vistas.PantallaMenu">
   <top>
      <MenuBar BorderPane.alignment="CENTER">
        <menus>
          <Menu mnemonicParsing="false" text="Juego">
               <items>
                  <MenuItem fx:id="newGame" mnemonicParsing="false" onAction="#handleNewGame" text="Juego nuevo" />
                  <MenuItem fx:id="saveGame" mnemonicParsing="false" onAction="#handleSaveGame" text="Guardar Juego " />
                  <MenuItem fx:id="loadGame" mnemonicParsing="false" onAction="#handleLoadGame" text="Cargar Juego" />
                  <MenuItem fx:id="quitGame" mnemonicParsing="false" onAction="#handleQuitGame" text="Salir Juego" />
               </items>
          </Menu>
        </menus>
      </MenuBar>
   </top>
   <center>
      <VBox alignment="TOP_CENTER" prefHeight="200.0" prefWidth="100.0" spacing="10.0" BorderPane.alignment="CENTER">
         <children>
            <Label text="Login" />
            <TextField fx:id="userField" promptText="Username" />
            <PasswordField fx:id="passField" promptText="Password" />
            <Button fx:id="loginButton" mnemonicParsing="false" onAction="#handleLogin" text="Login" />
            <Button fx:id="registerButton" mnemonicParsing="false" onAction="#handleRegister" text="Register" />
         </children>
      </VBox>
   </center>
</BorderPane>
