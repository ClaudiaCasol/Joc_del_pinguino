<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefWidth="900" prefHeight="600"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Vistas.CargarPartida"
            style="-fx-background-color: #eef7fb;">

    <top>
        <HBox style="-fx-background-color: #0b3c5d;" alignment="CENTER_LEFT">
            <children>

                <Label text="🐧  CARGAR PARTIDA"
                       style="-fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: bold;" />

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="Volver"
                        onAction="#volverPantallaModoJuego"
                        style="-fx-background-color: #7cc6e6;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 6;
                               -fx-padding: 8 18 8 18;" />

            </children>

            <padding>
                <Insets top="20" bottom="20" left="30" right="30"/>
            </padding>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <content>
                <VBox fx:id="contenedorPartidas" spacing="10">
                    <padding>
                        <Insets top="20" left="30" right="30" bottom="20"/>
                    </padding>
                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>