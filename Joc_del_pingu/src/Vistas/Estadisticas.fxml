<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="Vistas.Estadisticas"
            prefWidth="1500"
            prefHeight="900"
            style="-fx-background-color: linear-gradient(to bottom right,#c8ecff,#8bcdf3);">

    <top>

        <HBox spacing="20"
              alignment="CENTER_LEFT"
              style="-fx-background-color:#3ca7d6;
                     -fx-padding:25;">

            <Button text="← VOLVER"
                    onAction="#volverMenu"
                    style="-fx-background-color:#2ea4d1;
                           -fx-text-fill:white;
                           -fx-font-size:20;
                           -fx-font-weight:bold;
                           -fx-background-radius:18;" />

            <Text text="❄ CENTRO DE ESTADÍSTICAS">

                <style>
                    -fx-fill:white;
                    -fx-font-size:48;
                    -fx-font-weight:bold;
                </style>

            </Text>

        </HBox>

    </top>

    <center>

        <HBox spacing="30"
              style="-fx-padding:30;">

            <VBox spacing="20"
                  prefWidth="550"
                  style="-fx-background-color: rgba(255,255,255,0.15);
                         -fx-background-radius:30;
                         -fx-padding:25;">

                <Text text="🏆 RANKING GLOBAL">

                    <style>
                        -fx-fill:white;
                        -fx-font-size:32;
                        -fx-font-weight:bold;
                    </style>

                </Text>

                <ScrollPane fitToWidth="true"
                            style="-fx-background:transparent;
                                   -fx-background-color:transparent;">

                    <content>

                        <VBox fx:id="rankingContainer"
                              spacing="20"/>

                    </content>

                </ScrollPane>

            </VBox>


            <VBox spacing="25"
                  HBox.hgrow="ALWAYS">


<HBox spacing="20">


    <VBox spacing="15"
          HBox.hgrow="ALWAYS"
          style="-fx-background-color: rgba(255,255,255,0.18);
                 -fx-background-radius:25;
                 -fx-padding:25;">

        <Text text="👑 RECORD"
              style="-fx-fill:white;
                     -fx-font-size:28;
                     -fx-font-weight:bold;"/>

        <Text fx:id="recordLabel"
              style="-fx-fill:white;
                     -fx-font-size:54;
                     -fx-font-weight:bold;"/>

        <VBox fx:id="recordPlayersContainer"
              spacing="10"/>

    </VBox>

    <VBox spacing="15"
          HBox.hgrow="ALWAYS"
          style="-fx-background-color: rgba(255,255,255,0.18);
                 -fx-background-radius:25;
                 -fx-padding:25;">

        <Text text="📊 MEDIA"
              style="-fx-fill:white;
                     -fx-font-size:28;
                     -fx-font-weight:bold;"/>

        <Text fx:id="mediaLabel"
              style="-fx-fill:white;
                     -fx-font-size:54;
                     -fx-font-weight:bold;"/>

    </VBox>

</HBox>


<VBox spacing="15"
      style="-fx-background-color: rgba(255,255,255,0.18);
             -fx-background-radius:25;
             -fx-padding:25;">

    <Text text="❄ % SUPERADOS"
          style="-fx-fill:white;
                 -fx-font-size:28;
                 -fx-font-weight:bold;"/>

    <Text fx:id="porcentajeLabel"
          style="-fx-fill:white;
                 -fx-font-size:54;
                 -fx-font-weight:bold;"/>

</VBox>
                <VBox spacing="20"
                      VBox.vgrow="ALWAYS"
                      style="-fx-background-color: rgba(255,255,255,0.18);
                             -fx-background-radius:30;
                             -fx-padding:25;">

                    <Text text="📜 ACTIVIDAD RECIENTE"
                          style="-fx-fill:white;
                                 -fx-font-size:32;
                                 -fx-font-weight:bold;"/>

                    <VBox fx:id="actividadContainer"
                          spacing="15"/>

                </VBox>

            </VBox>

        </HBox>

    </center>

</BorderPane>