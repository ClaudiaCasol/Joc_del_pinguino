<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0"
      style="-fx-background-color: linear-gradient(#bde0fe, #90dbf4);"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Vistas.PantallaModoJuego">

    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/>
    </padding>

    <Label text="El Joc d'en Pingu 🐧"
           style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #0d3b66;"/>

    <Label fx:id="lblInfo"
           text="Selecciona el nombre de jugadors"
           style="-fx-font-size: 16; -fx-text-fill: #1d6fa4;"/>

    <Button fx:id="btn2Jugadors" text="2 Jugadors"
            onAction="#handle2Jugadors"
            prefWidth="220" prefHeight="45"
            style="-fx-background-color: #0077b6; -fx-text-fill: white;
                   -fx-font-size: 14; -fx-background-radius: 10;"/>

    <Button fx:id="btn3Jugadors" text="3 Jugadors"
            onAction="#handle3Jugadors"
            prefWidth="220" prefHeight="45"
            style="-fx-background-color: #0096c7; -fx-text-fill: white;
                   -fx-font-size: 14; -fx-background-radius: 10;"/>

    <Button fx:id="btn4Jugadors" text="4 Jugadors + CPU 🦭"
            onAction="#handle4Jugadors"
            prefWidth="220" prefHeight="45"
            style="-fx-background-color: #00b4d8; -fx-text-fill: white;
                   -fx-font-size: 14; -fx-background-radius: 10;"/>

    <Button fx:id="btnManual" text="📖 Manual d'usuari"
            onAction="#handleManual"
            prefWidth="220" prefHeight="40"
            style="-fx-background-color: #48cae4; -fx-text-fill: #0d3b66;
                   -fx-font-size: 13; -fx-background-radius: 10;
                   -fx-border-color: #0077b6; -fx-border-radius: 10; -fx-border-width: 1.5;"/>

</VBox>